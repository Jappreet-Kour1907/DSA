//Delete From Middle.

#include<stdio.h>
#include<stdlib.h>
 
struct Node{
    int data;
    struct Node* next;
};

struct Node* head = NULL;

struct Node* createNode(int data){
    struct Node* temp = (struct Node*)malloc(sizeof(struct Node));
    temp-> data = data;
    temp-> next = NULL;
    return temp;
}

int main(){
    int n;
    scanf("%d", &n);
    struct Node* tail = NULL;
    for(int i=0; i<n; i++){
        int value;
        scanf("%d", &value);
        struct Node* newNode = createNode(value);
        if(head == NULL)
            head = tail = newNode;
        else{
            tail-> next = newNode;
            tail = newNode;
        }
    }
    if(n == 1)
        head = NULL;
    else{
        int mid = n/2;
        struct Node* temp = head;
        int i = 0;
        while(i != mid-1){
            temp = temp-> next;
            i++;
        }
        temp-> next = temp-> next-> next;
    }
    if(head == NULL)
        printf("EMPTY");
    else{
        struct Node* temp = head;
        while(temp != NULL){
            printf("%d ", temp-> data);
            temp = temp-> next;
        }
    }
    return 0;
}
