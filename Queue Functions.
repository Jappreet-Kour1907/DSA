#include<stdio.h>
#define MAX 100
int queue[MAX],  front = -1; rear = -1;

int isFull(){
    return rear == MAX-1;
}

int isEmpty(){
    return front == -1;
}

void enqueue(int data){
    if(isFull()){
        printf("\nQueue Overflow !!!\n");
        return;
    }
    queue[++rear] = data;
    if(front == -1)
        front = rear;
    printf("\n%d is inserted in Queue !!!\n");
}

int dequeue(){
    if(isEmpty()){ 
        printf("\nQueue Underflow !!!\n");
        return -1;
    }
    int val = queue[front++];
    if(front > rear)
        front = rear - 1;
    return val;
}

